# Kafka (optional — default 127.0.0.1:9092 matches infra/docker-compose.yml)
# KAFKA_BOOTSTRAP=127.0.0.1:9092

# Telegram alerts
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# IBKR credentials (used by IBC to auto-login to IB Gateway)
# Leave blank if you prefer to log in manually
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password

# IBC installation path (Windows path as seen from WSL)
# Default is /mnt/c/IBC — only change if you installed IBC elsewhere
# IBC_PATH=/mnt/c/IBC
# IBC_WIN_PATH=C:\IBC

# IB Gateway version and installation path
# Default is 1045 installed at C:\Jts\ibgateway\1045
# IBKR_VERSION=1045
# IBKR_DIR=C:\Jts\ibgateway\1045
